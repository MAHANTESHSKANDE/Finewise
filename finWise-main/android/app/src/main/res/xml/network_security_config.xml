<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow all HTTP traffic for development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">192.168.0.167</domain>
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.1.100</domain>
        <domain includeSubdomains="true">172.18.0.1</domain>
        <domain includeSubdomains="true">172.17.0.1</domain>
        <domain includeSubdomains="true">172.19.0.1</domain>
    </domain-config>
    
    <!-- For development - allow cleartext for all domains -->
    <!-- Remove this in production -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
